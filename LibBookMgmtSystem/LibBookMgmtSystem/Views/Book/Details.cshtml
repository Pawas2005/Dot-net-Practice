@model LibBookMgmtSystem.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<h2>Book Details</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Book ID</dt>
            <dd class="col-sm-9">@Model.BookId</dd>

            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Author</dt>
            <dd class="col-sm-9">@Model.Author</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("C")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="List" class="btn btn-secondary">Back to List</a>
    <a asp-action="Delete" asp-route-id="@Model.BookId" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this book?');">Delete</a>
</div>
