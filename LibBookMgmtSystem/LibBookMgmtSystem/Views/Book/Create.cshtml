@model LibBookMgmtSystem.Models.Book

@{
    ViewData["Title"] = "Add New Book";
}

<h2>Add New Book</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="form-group mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Author" class="form-label"></label>
                <input asp-for="Author" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" required />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Add Book</button>
                <a asp-action="List" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
